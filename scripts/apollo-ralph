#!/usr/bin/env python3
"""apollo-ralph — opt-in Ralph-style project loop for Apollo."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from src import ralph_loop as ralph


def _paths(args) -> ralph.RalphPaths:
    return ralph.paths_for(args.root)


def cmd_init(args) -> int:
    paths = ralph.init_workspace(args.root, force=args.force)
    print(json.dumps({
        "ok": True,
        "root": str(paths.root),
        "prd": str(paths.prd),
        "progress": str(paths.progress),
        "state": str(paths.state),
    }, indent=2))
    return 0


def cmd_status(args) -> int:
    paths = _paths(args)
    prd = ralph.load_prd(paths.prd)
    print(json.dumps(ralph.status_summary(prd), indent=2))
    return 0


def cmd_next(args) -> int:
    paths = _paths(args)
    prd = ralph.load_prd(paths.prd)
    story = ralph.select_next_story(prd, include_failed=args.include_failed)
    if not story:
        print("COMPLETE")
        return 0
    if args.prompt:
        print(ralph.build_prompt(prd, story, ralph.read_progress(paths.progress)))
    else:
        print(json.dumps(story, indent=2))
    return 0


def cmd_record(args) -> int:
    paths = _paths(args)
    prd = ralph.load_prd(paths.prd)
    story = ralph.mark_story(prd, args.story_id, passes=args.passes, failed=args.failed)
    if args.learning:
        ralph.append_learning(paths.progress, story, args.learning)
    if args.agent_learning:
        ralph.append_agent_learning(paths.agent_learnings, args.agent_learning)
    ralph.save_prd(paths.prd, prd)
    ralph.append_iteration(paths.state, {
        "story_id": args.story_id,
        "passes": args.passes,
        "failed": args.failed,
        "learning": args.learning or "",
    })
    print(json.dumps({"ok": True, "story": story}, indent=2))
    return 0


def cmd_check(args) -> int:
    paths = _paths(args)
    result = ralph.run_quality_check(args.command)
    paths.logs.mkdir(parents=True, exist_ok=True)
    (paths.logs / "last_check.log").write_text(result["output"], encoding="utf-8")
    ralph.append_iteration(paths.state, {
        "kind": "check",
        "command": result["command"],
        "returncode": result["returncode"],
        "ok": result["ok"],
    })
    print(json.dumps({k: v for k, v in result.items() if k != "output"}, indent=2))
    return 0 if result["ok"] else result["returncode"] or 1


def cmd_run_once(args) -> int:
    paths = _paths(args)
    prd = ralph.load_prd(paths.prd)
    story = ralph.select_next_story(prd, include_failed=args.include_failed)
    if not story:
        print("COMPLETE")
        return 0
    prompt = ralph.build_prompt(prd, story, ralph.read_progress(paths.progress))
    if args.agent_cmd:
        try:
            proc = subprocess.run(
                args.agent_cmd,
                shell=True,
                input=prompt,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                timeout=args.timeout_minutes * 60,
            )
        except subprocess.TimeoutExpired as exc:
            output = ralph._coerce_output(exc.stdout) or f"Agent command timed out after {args.timeout_minutes:g} minutes"
            paths.logs.mkdir(parents=True, exist_ok=True)
            (paths.logs / f"{ralph.story_id(story)}.agent.log").write_text(output, encoding="utf-8")
            ralph.append_iteration(paths.state, {
                "story_id": ralph.story_id(story),
                "kind": "agent",
                "returncode": 124,
                "ok": False,
                "timed_out": True,
                "exit_signal": ralph.has_exit_signal(output),
            })
            print(output)
            return 124
        paths.logs.mkdir(parents=True, exist_ok=True)
        (paths.logs / f"{ralph.story_id(story)}.agent.log").write_text(proc.stdout or "", encoding="utf-8")
        if proc.returncode != 0:
            ralph.append_iteration(paths.state, {
                "story_id": ralph.story_id(story),
                "kind": "agent",
                "returncode": proc.returncode,
                "ok": False,
                "exit_signal": ralph.has_exit_signal(proc.stdout),
            })
            print(proc.stdout or "")
            return proc.returncode
        exit_signal = ralph.has_exit_signal(proc.stdout)
    else:
        print(prompt)
        return 0

    check = ralph.run_quality_check(args.check_command)
    (paths.logs / "last_check.log").write_text(check["output"], encoding="utf-8")
    verification_command = args.verification_command or ralph.story_verification_command(story)
    verification = {"ok": True, "command": "", "returncode": 0, "timed_out": False}
    if verification_command:
        verification = ralph.run_quality_check(verification_command)
        (paths.logs / "last_verification.log").write_text(verification["output"], encoding="utf-8")
    verified = bool(check["ok"] and verification["ok"])
    if verified and exit_signal and args.auto_mark:
        ralph.mark_story(prd, ralph.story_id(story), passes=True)
        ralph.save_prd(paths.prd, prd)
    ralph.append_iteration(paths.state, {
        "story_id": ralph.story_id(story),
        "kind": "run-once",
        "check_command": check["command"],
        "check_ok": check["ok"],
        "check_timed_out": check.get("timed_out", False),
        "verification_command": verification.get("command", ""),
        "verification_ok": verification["ok"],
        "verification_timed_out": verification.get("timed_out", False),
        "exit_signal": exit_signal,
        "auto_mark": args.auto_mark,
    })
    print(json.dumps({
        "story_id": ralph.story_id(story),
        "check_ok": check["ok"],
        "check_timed_out": check.get("timed_out", False),
        "verification_ok": verification["ok"],
        "exit_signal": exit_signal,
        "auto_marked": bool(verified and exit_signal and args.auto_mark),
    }, indent=2))
    if not check["ok"]:
        return check["returncode"] or 1
    if not verification["ok"]:
        return verification["returncode"] or 1
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="apollo-ralph")
    parser.add_argument("--root", default=ralph.DEFAULT_RALPH_DIR)
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_init = sub.add_parser("init")
    p_init.add_argument("--force", action="store_true")
    p_init.set_defaults(func=cmd_init)

    p_status = sub.add_parser("status")
    p_status.set_defaults(func=cmd_status)

    p_next = sub.add_parser("next")
    p_next.add_argument("--prompt", action="store_true")
    p_next.add_argument("--include-failed", action="store_true")
    p_next.set_defaults(func=cmd_next)

    p_record = sub.add_parser("record")
    p_record.add_argument("story_id")
    state = p_record.add_mutually_exclusive_group(required=True)
    state.add_argument("--passes", action="store_true")
    state.add_argument("--failed", action="store_true")
    p_record.add_argument("--learning", default="")
    p_record.add_argument("--agent-learning", default="")
    p_record.set_defaults(func=cmd_record)

    p_check = sub.add_parser("check")
    p_check.add_argument("--command", default=ralph.DEFAULT_CHECK_COMMAND)
    p_check.set_defaults(func=cmd_check)

    p_run = sub.add_parser("run-once")
    p_run.add_argument("--agent-cmd", default="")
    p_run.add_argument("--check-command", default=ralph.DEFAULT_CHECK_COMMAND)
    p_run.add_argument("--verification-command", default="")
    p_run.add_argument("--timeout-minutes", type=float, default=30)
    p_run.add_argument("--auto-mark", action="store_true")
    p_run.add_argument("--include-failed", action="store_true")
    p_run.set_defaults(func=cmd_run_once)

    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
