#!/usr/bin/env python3
"""apollo-logs — unified view of log files across the app.

Right now logs live in a few places:
  - logs/                       app-level (compound.log, future runtime)
  - /tmp/apollo-tmux/*.log    per-tmux-session model download/serve logs
  - .playwright-mcp/*.log      browser-test console captures
  - src/services search logs   legacy search-provider error logs

This CLI surfaces them so you don't have to remember which directory
holds what.

    apollo-logs list                    # every log we know about
    apollo-logs tail NAME               # tail -f a specific log
    apollo-logs tail NAME --lines 200   # last N lines only (no follow)
    apollo-logs cat NAME                # print full content
    apollo-logs clean                   # delete tmux logs older than 7 days
    apollo-logs clean --scope runtime   # dry-run runtime log cleanup
    apollo-logs clean --scope all --apply
"""
from __future__ import annotations

import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "_lib"))
from cli import quiet_logs, emit, fail, common_parser, run, REPO_ROOT as _REPO_ROOT

quiet_logs()

import argparse, json, subprocess, time
from datetime import datetime
from pathlib import Path


_APP_LOGS = _REPO_ROOT / "logs"
_TMUX_LOGS = Path("/tmp/apollo-tmux")
_BROWSER_LOGS = _REPO_ROOT / ".playwright-mcp"
_LEGACY_SEARCH_LOGS = (
    _REPO_ROOT / "src" / "search_engine_error.log",
    _REPO_ROOT / "services" / "search_engine_error.log",
)


def _log_paths(scope: str = "all") -> list[Path]:
    paths: list[Path] = []
    if scope in ("all", "runtime"):
        for base in (_APP_LOGS, _BROWSER_LOGS):
            if base.is_dir():
                paths.extend(sorted(base.glob("*.log")))
        paths.extend(p for p in _LEGACY_SEARCH_LOGS if p.exists())
    if scope in ("all", "tmux"):
        if _TMUX_LOGS.is_dir():
            paths.extend(sorted(_TMUX_LOGS.glob("*.log")))
    return paths


def _enumerate() -> list[dict]:
    """Return every known log file as {name, path, bytes, modified}."""
    out = []
    for p in _log_paths("all"):
        try:
            st = p.stat()
        except OSError:
            continue
        out.append({
            "name": p.name,
            "path": str(p),
            "bytes": st.st_size,
            "modified": datetime.fromtimestamp(st.st_mtime).isoformat(),
        })
    out.sort(key=lambda r: r["modified"], reverse=True)
    return out


def _resolve(name: str) -> Path | None:
    """Match a log by exact filename, basename-without-extension, or
    substring. Returns the most-recently-modified match if there are
    ties."""
    if not isinstance(name, str):
        return None
    candidates = []
    for p in _log_paths("all"):
        if p.name == name or p.stem == name or name in p.name:
            candidates.append(p)
    if not candidates:
        return None
    candidates.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    return candidates[0]


def cmd_list(args):
    emit(_enumerate(), args)


def cmd_tail(args):
    p = _resolve(args.name)
    if p is None:
        fail(f"no log matching {args.name!r}; run `apollo-logs list`")
    if args.follow:
        # Exec tail -f so signals + buffering are native.
        os.execvp("tail", ["tail", "-n", str(args.lines), "-f", str(p)])
    # Non-follow: print last N lines + exit.
    proc = subprocess.run(["tail", "-n", str(args.lines), str(p)],
                          capture_output=True, text=True)
    sys.stdout.write(proc.stdout)
    sys.exit(proc.returncode)


def cmd_cat(args):
    p = _resolve(args.name)
    if p is None:
        fail(f"no log matching {args.name!r}")
    sys.stdout.write(p.read_text(errors="replace"))


def _clean_candidates(scope: str, days: int) -> tuple[list[Path], int]:
    """Return (old_logs, kept_count) for cleanup planning."""
    cutoff = time.time() - days * 86400
    old, kept = [], 0
    for p in _log_paths(scope):
        try:
            if p.stat().st_mtime < cutoff:
                old.append(p)
            else:
                kept += 1
        except OSError:
            continue
    return old, kept


def cmd_clean(args):
    """Delete or dry-run cleanup for old log files."""
    old, kept = _clean_candidates(args.scope, args.days)
    apply_cleanup = bool(args.apply or args.scope == "tmux")
    deleted, errors = [], []
    if apply_cleanup:
        for p in old:
            try:
                p.unlink()
                deleted.append(str(p))
            except OSError as e:
                errors.append({"path": str(p), "error": str(e)})
    emit({
        "scope": args.scope,
        "dry_run": not apply_cleanup,
        "would_delete": [] if apply_cleanup else [str(p) for p in old],
        "deleted": deleted,
        "kept": kept,
        "errors": errors,
        "cutoff_days": args.days,
    }, args)


def _build_parser():
    p = common_parser("apollo-logs", "Tail / list logs across the app.")
    sub = p.add_subparsers(dest="cmd", required=True)

    pl = sub.add_parser("list", parents=p._common_parents)
    pl.set_defaults(func=cmd_list)

    pt = sub.add_parser("tail", parents=p._common_parents)
    pt.add_argument("name")
    pt.add_argument("-n", "--lines", type=int, default=80)
    pt.add_argument("-f", "--follow", action="store_true",
                    help="follow new lines (tail -f); omit for one-shot")
    pt.set_defaults(func=cmd_tail)

    pc = sub.add_parser("cat", parents=p._common_parents)
    pc.add_argument("name")
    pc.set_defaults(func=cmd_cat)

    pcl = sub.add_parser("clean", parents=p._common_parents)
    pcl.add_argument("--days", type=int, default=7,
                     help="clean logs older than N days (default 7)")
    pcl.add_argument("--scope", choices=["tmux", "runtime", "all"], default="tmux",
                     help="tmux keeps historical behavior; runtime/all dry-run unless --apply")
    pcl.add_argument("--apply", action="store_true",
                     help="actually delete runtime/all logs; tmux scope applies by default")
    pcl.set_defaults(func=cmd_clean)

    return p


if __name__ == "__main__":
    sys.exit(run(_build_parser()))
